{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Docs Atlas Desktop",
  "version": "0.22.0",
  "identifier": "io.docsatlas.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:web-shell",
    "beforeBuildCommand": "pnpm run build:web-shell",
    "devUrl": "http://127.0.0.1:43174",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "label": "main",
        "title": "Docs Atlas Desktop",
        "hiddenTitle": true,
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "titleBarStyle": "Overlay",
        "resizable": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
