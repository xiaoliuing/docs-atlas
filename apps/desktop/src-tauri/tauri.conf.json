{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Docs Atlas",
  "version": "0.37.13",
  "identifier": "io.docsatlas.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:web-shell",
    "beforeBuildCommand": "pnpm run build:web-shell",
    "devUrl": "http://127.0.0.1:43174",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://raw.githubusercontent.com https://cdn.jsdelivr.net https://github.com https://api.github.com"
    },
    "windows": [
      {
        "label": "main",
        "title": "Docs Atlas Desktop",
        "hiddenTitle": true,
        "backgroundColor": "#1F54D9",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "titleBarStyle": "Overlay",
        "acceptFirstMouse": true,
        "resizable": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": [
      "../../../docs"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/xiaoliuing/docs-atlas/main/desktop-updater/latest.json",
        "https://cdn.jsdelivr.net/gh/xiaoliuing/docs-atlas@main/desktop-updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzRDdGNzU5RjM0QkU1RApSV1JkdmpTZmRYODlEbFhnM0JlQnd3VGFYbWxXY0JOUk1EMC9UOG5rR2NRKzZOcmdLQmpnU3pEUQo="
    }
  }
}
