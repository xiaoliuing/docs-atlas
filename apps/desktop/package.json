    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0 || ^7.0.0 || ^8.0.0",
