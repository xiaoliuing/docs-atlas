{
  "name": "docs-atlas-workspace",
  "private": true,
  "version": "0.18.2",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @docs-atlas/web dev",
    "dev:desktop": "pnpm --filter @docs-atlas/desktop dev",
    "dev:desktop-web": "pnpm --filter @docs-atlas/desktop dev:web-shell",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @docs-atlas/web build",
    "build:desktop": "pnpm --filter @docs-atlas/desktop build",
    "preview": "pnpm preview:web",
    "preview:web": "pnpm --filter @docs-atlas/web preview",
    "preview:desktop": "pnpm --filter @docs-atlas/desktop preview",
    "check:shared-types": "pnpm --filter @docs-atlas/shared-types check",
    "check:workspace-db": "pnpm --filter @docs-atlas/workspace-db check"
  }
}
